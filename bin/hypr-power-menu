#!/usr/bin/env python3
import gi, subprocess, math
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk

BG = (28/255, 28/255, 32/255, 0.82)
RADIUS = 10

# (label, command, symbol, color, css_class)
ACTIONS = [
    ("Shutdown", "systemctl poweroff", "⏻", "#e05555", "sym-large"),
    ("Restart",  "systemctl reboot",   "↺", "#e0a040", "sym-normal"),
    ("Sleep",    "systemctl suspend",  "⏾", "#5599e0", "sym-normal"),
]

CSS = b"""
button {
    background: rgba(255,255,255,0.07);
    border: none;
    border-radius: 12px;
    padding: 12px 16px;
    min-width: 120px;
    min-height: 150px;
    transition: none;
    animation: none;
    background-image: none;
    box-shadow: none;
    outline: none;
}
button:hover {
    background: rgba(255,255,255,0.18);
    transition: none;
    animation: none;
    background-image: none;
    box-shadow: none;
}
button:focus {
    background: rgba(255,255,255,0.28);
    outline: none;
    box-shadow: inset 0 0 0 2px rgba(15, 15, 35, 0.85);
    transition: none;
    animation: none;
    background-image: none;
}
button:active {
    transition: none;
    animation: none;
    background-image: none;
}
button image {
    opacity: 0;
    min-width: 0;
    min-height: 0;
}
label {
    color: #e0e0e0;
    font-size: 12px;
}
.index-hint {
    color: rgba(255,255,255,0.4);
    font-size: 10px;
}
.sym-normal { font-size: 80px;  }
.sym-large  { font-size: 100px; }
"""

class PowerMenu(Gtk.Window):
    def __init__(self):
        super().__init__()
        self.set_title("hypr-power-menu")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_keep_above(True)
        self.set_type_hint(Gdk.WindowTypeHint.DIALOG)

        screen = self.get_screen()
        visual = screen.get_rgba_visual()
        if visual:
            self.set_visual(visual)
        self.set_app_paintable(True)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(screen, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        box = Gtk.Box(spacing=12)
        box.set_margin_top(20)
        box.set_margin_bottom(20)
        box.set_margin_start(20)
        box.set_margin_end(20)
        self.add(box)

        self.buttons = []
        self.focused = 0

        for i, (name, cmd, symbol, color, sym_class) in enumerate(ACTIONS):
            btn = Gtk.Button()
            btn.set_relief(Gtk.ReliefStyle.NONE)
            btn.set_can_focus(True)

            vbox = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=0)

            # index hint — top
            hint = Gtk.Label(label=str(i + 1))
            hint.get_style_context().add_class("index-hint")
            vbox.pack_start(hint, False, False, 0)

            # symbol — expands to fill all middle space, centered within it
            sym = Gtk.Label()
            sym.set_markup(f'<span foreground="{color}">{symbol}</span>')
            sym.get_style_context().add_class(sym_class)
            sym.set_valign(Gtk.Align.CENTER)
            vbox.pack_start(sym, True, True, 0)

            # action name — pinned to bottom
            lbl = Gtk.Label(label=name)
            vbox.pack_end(lbl, False, False, 0)

            btn.add(vbox)
            btn.connect("clicked", self.run_action, cmd)

            idx = i
            btn.connect("focus-in-event", lambda _w, _e, n=idx: self._sync_focus(n))

            box.pack_start(btn, False, False, 0)
            self.buttons.append(btn)

        self.connect("draw", self.on_draw)
        self.connect("key-press-event", self.on_key)
        self.connect("destroy", Gtk.main_quit)
        self.show_all()
        self.buttons[0].grab_focus()

    def on_draw(self, widget, cr):
        w = widget.get_allocated_width()
        h = widget.get_allocated_height()
        r = RADIUS
        cr.set_operator(1)
        cr.set_source_rgba(0, 0, 0, 0)
        cr.paint()
        cr.set_operator(2)
        cr.new_sub_path()
        cr.arc(r,   r,   r, math.pi,    3*math.pi/2)
        cr.arc(w-r, r,   r, -math.pi/2, 0)
        cr.arc(w-r, h-r, r, 0,          math.pi/2)
        cr.arc(r,   h-r, r, math.pi/2,  math.pi)
        cr.close_path()
        cr.set_source_rgba(*BG)
        cr.fill()
        return False

    def _sync_focus(self, idx):
        self.focused = idx

    def run_action(self, _btn, cmd):
        Gtk.main_quit()
        subprocess.Popen(cmd, shell=True)

    def on_key(self, _w, event):
        k = event.keyval

        if k == Gdk.KEY_Escape:
            Gtk.main_quit()
            return True

        if k in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            _, cmd, _, _, _ = ACTIONS[self.focused]
            Gtk.main_quit()
            subprocess.Popen(cmd, shell=True)
            return True

        if k in (Gdk.KEY_Left, Gdk.KEY_Up):
            self.focused = (self.focused - 1) % len(self.buttons)
            self.buttons[self.focused].grab_focus()
            return True

        if k in (Gdk.KEY_Right, Gdk.KEY_Down):
            self.focused = (self.focused + 1) % len(self.buttons)
            self.buttons[self.focused].grab_focus()
            return True

        if Gdk.KEY_1 <= k <= Gdk.KEY_1 + len(ACTIONS) - 1:
            _, cmd, _, _, _ = ACTIONS[k - Gdk.KEY_1]
            Gtk.main_quit()
            subprocess.Popen(cmd, shell=True)
            return True

        return False

if __name__ == "__main__":
    PowerMenu()
    Gtk.main()
