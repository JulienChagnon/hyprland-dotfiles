#!/usr/bin/env bash
# hypr-settings-picker — network/clock toggles + gap, border, and cursor presets (SUPER+I)

NET_STATE="$HOME/.config/waybar/.net_shown"
CLOCK_STATE="$HOME/.config/waybar/.clock_hidden"
CONFIG="$HOME/.config/waybar/config.jsonc"
KITTY_CONF="$HOME/.config/kitty/kitty.conf"

apply_net_state() {
    local file="$1"
    local with_net='"modules-right": ["custom/weather", "cpu", "memory", "pulseaudio", "tray", "custom/sep", "custom/net-wifi", "custom/net-eth"]'
    local without_net='"modules-right": ["custom/weather", "cpu", "memory", "pulseaudio", "tray"]'
    if [ -f "$NET_STATE" ]; then
        python3 -c "
import re
content = open('$file').read()
content = re.sub(r'\"modules-right\":\s*\[[^\]]*\]', '$with_net', content)
open('$file', 'w').write(content)
"
    else
        python3 -c "
import re
content = open('$file').read()
content = re.sub(r'\"modules-right\":\s*\[[^\]]*\]', '$without_net', content)
open('$file', 'w').write(content)
"
    fi
}

apply_clock_state() {
    local file="$1"
    local with_clock='"modules-center": ["clock"]'
    local without_clock='"modules-center": []'
    if [ -f "$CLOCK_STATE" ]; then
        python3 -c "
import re
content = open('$file').read()
content = re.sub(r'\"modules-center\":\s*\[[^\]]*\]', '$without_clock', content)
open('$file', 'w').write(content)
"
    else
        python3 -c "
import re
content = open('$file').read()
content = re.sub(r'\"modules-center\":\s*\[[^\]]*\]', '$with_clock', content)
open('$file', 'w').write(content)
"
    fi
}

set_kitty_cursor() {
    local shape="$1" opacity="$2"

    # ANSI cursor shape escape codes: 2=steady block, 4=steady underline, 6=steady beam
    local esc_code
    case "$shape" in
        block)     esc_code=2 ;;
        underline) esc_code=4 ;;
        beam)      esc_code=6 ;;
        *)         esc_code=0 ;;
    esac

    python3 -c "
import re
path = '$KITTY_CONF'
content = open(path).read()
content = re.sub(r'^cursor_shape .*$',  'cursor_shape $shape',   content, flags=re.M)
content = re.sub(r'^cursor_opacity .*$','cursor_opacity $opacity',content, flags=re.M)
open(path, 'w').write(content)
"
    pkill -USR1 kitty 2>/dev/null || true

    # Also push the escape sequence directly to each open kitty window's PTY so
    # the cursor changes immediately (SIGUSR1 only applies to new windows when
    # an app has already set the cursor via escape sequences).
    for kitty_pid in $(pgrep kitty 2>/dev/null); do
        for child_pid in $(pgrep -P "$kitty_pid" 2>/dev/null); do
            local tty_path
            tty_path=$(readlink "/proc/$child_pid/fd/0" 2>/dev/null)
            if [[ "$tty_path" == /dev/pts/* && -w "$tty_path" ]]; then
                printf "\033[${esc_code} q" > "$tty_path" 2>/dev/null || true
            fi
        done
    done
}

wifi=$'\uf1eb'  # Font Awesome 6 Free wifi glyph

if [ -f "$NET_STATE" ]; then
    net_label="${wifi}  Network: ON   — toggle off"
else
    net_label="${wifi}  Network: OFF  — toggle on"
fi

if [ -f "$CLOCK_STATE" ]; then
    clock_label="🕐  Clock: OFF  — toggle on"
else
    clock_label="🕐  Clock: ON   — toggle off"
fi

# Read current values to mark active preset
cur_gi=$(hyprctl getoption general:gaps_in    -j 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('int', d.get('custom','3 3 3 3')).split()[0])" 2>/dev/null || echo 3)
cur_go=$(hyprctl getoption general:gaps_out   -j 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('int', d.get('custom','12 12 12 12')).split()[0])" 2>/dev/null || echo 12)
cur_bs=$(hyprctl getoption general:border_size -j 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('int', d.get('custom','2')))" 2>/dev/null || echo 2)
cur_cursor=$(grep -m1 '^cursor_shape' "$KITTY_CONF" 2>/dev/null | awk '{print $2}')
[ -z "$cur_cursor" ] && cur_cursor="block"

dot() { [[ "$1" == "$2" ]] && printf " ●" || printf ""; }

display_list="${net_label}\n${clock_label}"
display_list+="\n── Gaps ──────────────────────"
display_list+="\nGaps: None   (0 / 0)$(dot "${cur_gi}-${cur_go}" "0-0")"
display_list+="\nGaps: Small  (2 / 6)$(dot "${cur_gi}-${cur_go}" "2-6")"
display_list+="\nGaps: Medium (3 / 12)$(dot "${cur_gi}-${cur_go}" "3-12")"
display_list+="\nGaps: Large  (6 / 20)$(dot "${cur_gi}-${cur_go}" "6-20")"
display_list+="\n── Border ────────────────────"
display_list+="\nBorder: None   (0px)$(dot "$cur_bs" "0")"
display_list+="\nBorder: Thin   (1px)$(dot "$cur_bs" "1")"
display_list+="\nBorder: Normal (2px)$(dot "$cur_bs" "2")"
display_list+="\nBorder: Thick  (3px)$(dot "$cur_bs" "3")"
display_list+="\n── Cursor ────────────────────"
display_list+="\nCursor: Block  (dim)$(dot "$cur_cursor" "block")"
display_list+="\nCursor: Beam   (2.5px)$(dot "$cur_cursor" "beam")"

(sleep 0.3 && hyprctl dispatch focuswindow class:wofi 2>/dev/null) &

chosen=$(printf "%b" "$display_list" | wofi --dmenu \
    --prompt "  Settings" \
    --width 380 \
    --height 510 \
    --cache-file /dev/null \
    --style "$HOME/.config/wofi/style-settings.css")

[ -z "$chosen" ] && exit 0
[[ "$chosen" == "──"* ]] && exit 0

# Network toggle
if [[ -n "$wifi" && "$chosen" == "${wifi}"* ]] || [[ "$chosen" == *"Network:"* ]]; then
    [ -f "$NET_STATE" ] && rm "$NET_STATE" || touch "$NET_STATE"
    apply_net_state "$CONFIG"
    apply_clock_state "$CONFIG"
    pkill -x waybar
    sleep 0.3
    waybar &
    disown
    exit 0
fi

# Clock toggle
if [[ "$chosen" == "🕐"* ]]; then
    [ -f "$CLOCK_STATE" ] && rm "$CLOCK_STATE" || touch "$CLOCK_STATE"
    apply_net_state "$CONFIG"
    apply_clock_state "$CONFIG"
    pkill -x waybar
    sleep 0.3
    waybar &
    disown
    exit 0
fi

# Gap presets
if [[ "$chosen" == "Gaps:"* ]]; then
    case "$chosen" in
        *None*)   hyprctl keyword general:gaps_in 0;  hyprctl keyword general:gaps_out 0  ;;
        *Small*)  hyprctl keyword general:gaps_in 2;  hyprctl keyword general:gaps_out 6  ;;
        *Medium*) hyprctl keyword general:gaps_in 3;  hyprctl keyword general:gaps_out 12 ;;
        *Large*)  hyprctl keyword general:gaps_in 6;  hyprctl keyword general:gaps_out 20 ;;
    esac
    exit 0
fi

# Border presets
if [[ "$chosen" == "Border:"* ]]; then
    case "$chosen" in
        *None*)   hyprctl keyword general:border_size 0 ;;
        *Thin*)   hyprctl keyword general:border_size 1 ;;
        *Normal*) hyprctl keyword general:border_size 2 ;;
        *Thick*)  hyprctl keyword general:border_size 3 ;;
    esac
    exit 0
fi

# Cursor presets
if [[ "$chosen" == "Cursor:"* ]]; then
    case "$chosen" in
        *Block*) set_kitty_cursor block 0.7 ;;
        *Beam*)  set_kitty_cursor beam  1.0 ;;
    esac
    exit 0
fi
