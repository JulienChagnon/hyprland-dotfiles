#!/usr/bin/env python3
"""
hypr-reopen-last — reopens the last window closed under Hyprland.

Reads the snapshot written by hypr-window-tracker and relaunches the window
with context-aware logic:
  - Terminal running claude  → new terminal with `claude --continue` in same cwd
  - Terminal running a cmd   → new terminal re-running that command in same cwd
  - Idle terminal            → new terminal in the same cwd
  - Any other app            → exec the window class as a command

Bound to SUPER+T in hyprland.conf.
"""

import json
import os
import subprocess
import sys
from pathlib import Path

STATE_FILE = Path.home() / ".local/share/hypr-reopen/last_closed.json"
TERMINAL = "kitty"
SHELLS = {"bash", "zsh", "fish", "sh", "dash", "ksh"}
TERMINAL_CLASSES = {"kitty", "foot", "alacritty", "wezterm", "gnome-terminal", "xterm"}


def launch(*args):
    """Fire-and-forget process launch, fully detached from this process."""
    subprocess.Popen(list(args), start_new_session=True,
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def main():
    if not STATE_FILE.exists():
        sys.exit(0)

    try:
        snap = json.loads(STATE_FILE.read_text())
    except Exception:
        sys.exit(1)

    wclass = snap.get("class", "").lower()
    cwd = snap.get("cwd") or str(Path.home())
    foreground_cmd = snap.get("foreground_cmd") or ""
    cmd_parts = foreground_cmd.split() if foreground_cmd else []
    cmd_name = os.path.basename(cmd_parts[0]) if cmd_parts else ""

    if wclass in TERMINAL_CLASSES:
        if "claude" in cmd_name or "claude" in foreground_cmd:
            # Resume the Claude Code session in the same project directory
            launch(TERMINAL, "--working-directory", cwd, "-e", "claude", "--continue")

        elif foreground_cmd and cmd_name not in SHELLS:
            # Re-run the foreground command; drop back to shell when it exits
            launch(TERMINAL, "--working-directory", cwd,
                   "-e", "bash", "-c", f"{foreground_cmd}; exec bash")

        else:
            # Idle shell — just reopen the terminal in the same directory
            launch(TERMINAL, "--working-directory", cwd)

    else:
        # Non-terminal app: best-effort relaunch by window class
        try:
            launch(wclass)
        except Exception:
            pass


if __name__ == "__main__":
    main()
